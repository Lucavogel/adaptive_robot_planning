<?xml version="1.0"?>
<robot name="lynx_ses900">

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="base_material">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Shoulder Link -->
  <link name="shoulder_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="shoulder_material">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <!-- Upper Arm Link -->
  <link name="upper_arm_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="upper_arm_material">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0.2 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <!-- Forearm Link -->
  <link name="forearm_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="forearm_material">
        <color rgba="0.2 0.8 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Wrist Link -->
  <link name="wrist_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wrist_material">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Hand Link -->
  <link name="hand_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="hand_material">
        <color rgba="0.8 0.8 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- Tool Link -->
  <link name="tool_link">
    <visual>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="tool_material">
        <color rgba="0.2 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://URDF_description/meshes/link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Base to Shoulder Joint -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="2.967" effort="50" velocity="1.5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Shoulder to Upper Arm Joint -->
  <joint name="joint_2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="-0.04 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="50" velocity="1.5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Upper Arm to Forearm Joint -->
  <joint name="joint_3" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="-0.045 0 0.415" rpy="0 0 3.1416"/> <!-- 180° autour de Z -->
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="40" velocity="1.5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Forearm to Wrist Joint -->
  <joint name="joint_4" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="-0.05 0 0.05" rpy="0 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="30" velocity="1.5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Wrist to Hand Joint -->
  <joint name="joint_5" type="revolute">
    <parent link="wrist_link"/>
    <child link="hand_link"/>
    <origin xyz="-0.06 0 0.335" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="20" velocity="1.5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Hand to Tool Joint -->
  <joint name="joint_6" type="revolute">
    <parent link="hand_link"/>
    <child link="tool_link"/>
    <origin xyz="-0.05 0 -0.07" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- TCP Link pour MoveIt -->
  <link name="tcp"/>

  <!-- Tool to TCP Joint -->
  <joint name="tool_to_tcp" type="fixed">
    <parent link="tool_link"/>
    <child link="tcp"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

</robot>
